{
  "workspace": {
    "path": "${REPO_DIR}/workspace"
  },
  "core_config_dirs": [
    {
      "id": "claude-default",
      "type": "claude",
      "env_name": "CLAUDE_CONFIG_DIR",
      "synced": true,
      "value": "${WORKSPACE_DIR}/.claude-sutando"
    }
  ],
  "vault": {
    "enabled": false,
    "remote_url": "",
    "sync": {
      "include": [
        "notes/",
        "hosts/*/",
        ".claude-sutando/projects/*/memory/"
      ],
      "exclude": [
        "tasks/",
        "results/"
      ]
    },
    "interval_seconds": 1800
  }
}
