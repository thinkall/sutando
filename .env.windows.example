# ============================================================
# Sutando — Windows + GitHub Copilot CLI minimal config
# ============================================================
#
# Copy this file to .env and edit as needed.
#   Copy-Item .env.windows.example .env
#
# All values are optional. Sutando works on Windows with GitHub Copilot CLI
# as the core agent — no Gemini API key, no Twilio, no Claude Code needed.

# ============================================================
# Optional — LAN access (so you can use Sutando from your phone)
# ============================================================

# Bind the agent API to all interfaces (default: 127.0.0.1).
# REQUIRED if you want to reach Sutando from your phone over Wi-Fi.
# When set to 0.0.0.0 you MUST also set SUTANDO_API_TOKEN below.
# AGENT_API_BIND=0.0.0.0

# Required when AGENT_API_BIND is non-loopback. Any random string.
# The web form picks this up via the URL ?token=XXX query parameter.
# Without it, anyone on your LAN could submit prompts to Copilot.
# Generate one in PowerShell:
#   -join ((1..32) | % { [char]((97..122) + (48..57) | Get-Random) })
# SUTANDO_API_TOKEN=replace-me-with-32-random-chars

# ============================================================
# Optional — Copilot task runner tuning
# ============================================================

# Custom path to the copilot binary (default: just `copilot` on PATH).
# COPILOT_BIN=C:\Users\you\AppData\Roaming\npm\copilot.cmd

# Per-task timeout in milliseconds (default: 600000 = 10 minutes).
# COPILOT_TASK_TIMEOUT_MS=600000

# Task-poll interval in milliseconds (default: 500).
# COPILOT_POLL_INTERVAL_MS=500

# ============================================================
# Optional — Edge-TTS voice
# ============================================================

# Voice name. List voices:  python -m edge_tts --list-voices
# Default: en-US-AriaNeural
# EDGE_TTS_VOICE=en-US-AriaNeural

# Speech rate, e.g. "+10%" or "-20%". Default: +0%
# EDGE_TTS_RATE=+0%

# Truncate text past this many chars (default: 4000).
# EDGE_TTS_MAX_CHARS=4000

# Edge-TTS poll interval (default: 1000 ms).
# EDGE_TTS_POLL_MS=1000
