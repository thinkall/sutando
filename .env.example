# ============================================================
# REQUIRED — Sutando won't start without these
# ============================================================

# Google AI Studio API key (vision + image/video generation; voice too when
# GEMINI_VOICE_API_KEY is unset).
# Get one free: https://ai.google.dev → "Get API key"
GEMINI_API_KEY=your-gemini-key

# Optional: separate key for the voice session (Gemini Live + STT + subagent
# text LLM). Voice on the free tier is unlimited (rate-limited, no metered
# charges), so using a free-tier key here isolates voice from any paid-tier
# spend on GEMINI_API_KEY — useful when GEMINI_API_KEY is on a billing-enabled
# project for image/video generation.
# If unset, voice uses GEMINI_API_KEY.
# GEMINI_VOICE_API_KEY=your-free-tier-voice-key

# ============================================================
# RECOMMENDED — not required but makes Sutando more useful
# ============================================================

# Email for health alerts (your email address)
# NOTIFICATION_EMAIL=you@example.com

# Voice agent WebSocket port (default: 9900)
PORT=9900

# ============================================================
# OPTIONAL — add these when you need specific features
# ============================================================

# Optional: Twilio for phone calls and SMS
# Get started: https://www.twilio.com (free trial available, ~$1/month for a number)
# Enables: crisis phone alerts, meeting dial-in, incoming call handling
# TWILIO_ACCOUNT_SID=ACxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Optional: X (Twitter) API — enables the x-twitter skill (post / search / read).
# Two auth modes:
#   - X_BEARER_TOKEN alone: read-only commands (search, read) work with just the
#     app-only bearer token. Zero dependencies — uses stdlib urllib.
#   - X_API_KEY + X_API_SECRET + X_ACCESS_TOKEN + X_ACCESS_TOKEN_SECRET: required
#     for write / user-context commands (post, mentions, timeline).
# Get creds at https://developer.x.com — free tier covers search/read.
# X_BEARER_TOKEN=AAAAAAAAAAAA...
# X_API_KEY=xxxxxxxxx
# X_API_SECRET=xxxxxxxxx
# X_ACCESS_TOKEN=xxxxxxxxx
# X_ACCESS_TOKEN_SECRET=xxxxxxxxx
# TWILIO_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.dev  # run: ngrok http 3100
# NGROK_DOMAIN=your-reserved-subdomain.ngrok-free.dev  # optional — reserved domain for stable URL (recommended)
# If NGROK_DOMAIN is set, startup.sh passes --domain to ngrok so the tunnel
# URL stays the same across restarts and the Twilio webhook never needs
# manual updates. Get one from https://dashboard.ngrok.com/domains (free tier
# includes one reserved domain per account).
#
# Phone access control — 3 tiers:
#
# Owner (OWNER_NUMBER): full access — work tool (task delegation), all inline
#   tools (summon, call_contact, screen control, browser, clipboard, etc.)
# Verified (VERIFIED_CALLERS): limited tools — volume, brightness, time,
#   meeting ID lookup. No task delegation, no screen/file/email access.
# Unverified: conversation only, hang_up only.
#
# OWNER_NUMBER=+14155551234
# VERIFIED_CALLERS=+14155551234,+14155555678

# Optional: Meeting IDs that grant the agent OS access (task delegation).
# For Google Meet: use the phone PIN (from calendar conferenceData).
# For Zoom: use the meeting ID.
# Unverified meetings: agent joins and takes notes only (no task delegation).
# VERIFIED_MEETINGS=1234567890,9876543210

# Optional: Personal Zoom meeting ID — used as default for "start Zoom" / "share my screen"
# ZOOM_PERSONAL_MEETING_ID=1234567890
# ZOOM_PERSONAL_PASSCODE=123456
# ZOOM_DEFAULT_SHARE_SCREEN=true # "true" = share screen, "false" = join only (default: true)

# Optional: Agent API authentication (for remote access)
# Set to any random string. Clients pass it as: Authorization: Bearer <token>
# SUTANDO_API_TOKEN=your-secret-token

# Optional: Telegram bot for messaging Sutando from your phone
# Create a bot via @BotFather on Telegram, get the token.
# Token is saved to $CLAUDE_CONFIG_DIR/channels/telegram/.env (not here).
# Setup: /telegram:configure <token>
# Access: /telegram:access allow <your-telegram-user-id>

# Optional: Discord bot for messaging Sutando from Discord
# Create at: https://discord.com/developers/applications
# Enable Message Content Intent in bot settings.
# Token is saved to $CLAUDE_CONFIG_DIR/channels/discord/.env (not here).
# Setup: /discord:configure <token>
# Access: /discord:access policy allowlist

# Optional: Private memory sync repo
# Create a PRIVATE GitHub repo to sync memory + notes between machines.
# sync-memory.sh skips silently if this is unset.
# SUTANDO_MEMORY_REPO=git@github.com:youruser/sutando-memory.git

# Optional: Deterministic ownership for team/other-tier Discord tasks
# When set, only the node whose stand-identity.json `machine` field matches
# SUTANDO_TEAM_TIER_OWNER will accept non-owner-tier tasks. Other nodes drop
# them silently. Prevents the dup-processing that otherwise burns 2× codex
# quota and posts 2 replies whenever both bots receive the same team @mention.
#
# Set the SAME value on both nodes' .env. Owner-tier tasks are unaffected
# (always processed locally).
# SUTANDO_TEAM_TIER_OWNER=mac-mini

# ============================================================
# MODEL CONFIGURATION — override defaults for cost/quality tuning
# ============================================================

# Voice conversation LLM (bodhi VoiceSession reasoning + tool calling)
# VOICE_MODEL=gemini-2.5-flash

# Native audio model (STT+LLM+TTS in one round trip for real-time voice)
# VOICE_NATIVE_AUDIO_MODEL=gemini-3.1-flash-live-preview

# Gemini Live prebuilt synthesis voice (default: Puck).
# Male-perceived: Puck, Charon, Fenrir, Orus
# Female-perceived: Aoede, Kore, Zephyr
# Newer models also expose: Leda, Sulafat, Algenib, Despina
# Unsupported names fail at Gemini setup-complete (WebSocket close 1007).
# VOICE_NAME=Puck

# Screen vision model (20-word screenshot descriptions — flash-lite is cheapest)
# VISION_MODEL=gemini-3.1-flash-lite

# Pointer Teacher vision model (point_at). gemini-3-flash-preview is POC-proven
# (1–3px, native [y,x] format, thinking off — see docs/adr/0001). Verified on
# Google's deprecation page 2026-05-19: no shutdown date announced. Escape
# hatch: if Google later deprecates the -preview id, set the GA id here — the
# code reads this env var, so no code change is needed.
# POINTER_MODEL=gemini-3-flash-preview

# Image generation model
# IMAGE_MODEL=gemini-3.1-flash-image-preview

# Video generation model
# VIDEO_MODEL=veo-3.1-generate-preview

# Cartesia (TTS) — set CARTESIA_API_KEY to enable post-task result audio
# CARTESIA_API_KEY=your-cartesia-key
# CARTESIA_VOICE_ID=f786b574-daa5-4673-aa0c-cbe3e8534c02
# GitHub webhook bridge — signature verification secret.
# Must match the secret configured in GitHub repo Settings → Webhooks → Secret.
# If not set, all webhook payloads are rejected (fail-closed).
# GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# sutando workspace — for a normal git-clone install you don't need this.
# Workspace location is configured via sutando.config.local.json (see
# docs/workspace-config.md). The env var is honored as a legacy escape
# hatch only and emits a deprecation warning at startup.
# SUTANDO_WORKSPACE=/path/to/workspace

# Optional: WhatsApp via wacli (CLI — not used by Node startup, for the agent).
# Install:  brew install steipete/tap/wacli
# Auth:     wacli auth   (QR code; one-time per Mac)
# Skill:    skills/whatsapp/SKILL.md
# These vars are read by wacli itself and set the label/platform shown in
# WhatsApp → Linked Devices on the user's phone.
# WACLI_DEVICE_LABEL=Sutando
# WACLI_DEVICE_PLATFORM=CHROME

# AG2 remote relay. Paste the onboarding string you received; startup.sh
# auto-starts the relay client when set.
# AG2_REMOTE_TOKEN=paste-your-onboarding-string-here
